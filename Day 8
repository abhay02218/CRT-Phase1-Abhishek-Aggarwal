//Problem 2 -- Polymorphism
//Types -- 2.1 Function Overriding 

#include<iostream>
using namespace std;

class Animal {
    public:
    virtual void sound(){
        cout << "Animal makes sound";
    }
};

class Dog : public Animal{
    public:
    void sound() override {
        cout << "Dog barks. "<< "\n" ;
    }
};

class Cat : public Animal {
    public:
    void sound() override {
        cout << "Cat meaows. " << "\n" ;
    }
};

int main() {
    Dog d;
    Cat c;
    d.sound();
    c.sound();
} 
