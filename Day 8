//Types -- 1.4 Multiple Imheritance 

#include <iostream>
using namespace std;

class parent1 {
    public:
    void giveMeMoney(){
        cout << "Mummy Pisaa do " << "\n";
    }
};

class parent2 {
    public:
    void giveMeMoney(){
        cout << "Papa pisaa do " << "\n";
    }
};

class child : public parent1, public parent2 {
    //No Logic
};

int main(){
    child obj1;
    //obj1.giveMeMoney();
    obj1.parent1::giveMeMoney();
    obj1.parent2::giveMeMoney();
}

