//Types -- 1.3 Hierachical Inheritance

#include <iostream>
using namespace std;

class Vehicle {
    public:
    void start(){
        cout << "Vehicle  Starts." << "\n";
        }
};

class Bike: public Vehicle{
    public:
    void ride(){
        cout << "Bike is running. " << "\n";
    }
};

class Car: public Vehicle{
    public:
    void drive(){
        cout << "Car is running."<< "\n";
    }
};

int main (){
    Car obj1;
    Bike obj2;
    
    obj1.start();
    obj1.drive();
    obj2.ride();
}

