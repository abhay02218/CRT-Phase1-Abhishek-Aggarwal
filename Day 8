//Types -- 2.2 Function Overriding

#include<iostream>
using namespace std;

class Parent {
    public:
    virtual void sum (int a, int b){
        cout << a+b << "Parent";
    }
};
 
class child : public Parent{
    public:
    void sum(int a, int b ) override{
        cout << a + b << " child ";
    }
};
 
int main() {
    child c;
    c.sum(10,20);
}    

