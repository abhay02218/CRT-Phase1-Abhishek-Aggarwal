class A {
public: 
    void print(){
        cout << "BJP Wons";
    }
};
class B : virtual public A {
    // NO LOGIC
};

class C : virtual public A {
    // NO LOGIC
};

class D : public B, public C {
    // NO LOGIC
};

int main() {
    D obj1;
    obj1.print();
}

