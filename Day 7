//Program -- 3
//Pillar of OOPs
// Encapsulation
//Encapsulation means we are binding the data into a single unit(Functions, data, variables, mehods)
  called class and making some restrictions on this class members.
//Data Security
//Controlled access over my data
//
//

#include <iostream>
using namespace std;

class bankAccount{
    private:
    int balance;
    
    public:
    void setbalance(int amount){
        if(amount >= 0){
            balance = amount;
        }else{
            cout << "Enter a valid Number...";
        }
    }
    public:
    int getbalance() {
        return balance;
    }
};
int main() {
    bankAccount obj1;
    obj1.setbalance(7000);
    cout << obj1.getbalance();
}


