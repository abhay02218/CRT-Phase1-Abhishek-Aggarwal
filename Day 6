//Problem 5 -- Smart Ac remote //Function Overloading



#include  <iostream>
using namespace std;

void setTemprature(int temp = 24){
    cout << "Temprature set to "  << temp << "°C" << "\n" ;
}

void setTemprature(double temp){
    cout << "Temprature set to "  << temp << "°C" << "\n" ;
}

void setTemprature(string mode){
    if(mode == "ECO"){
        cout << "Temprature set to 22 °C" << "\n";
    }else if(mode == "TURBO"){
        cout << "Temprature set to 20 °C" << "\n";
    }
}

int main(){
    setTemprature() ; // default value -- 24
    setTemprature(19.5);//manually setting the Temprature
    setTemprature("ECO");// setTemprature to 22
    setTemprature("TURBO");// setTemprature to 20
}

