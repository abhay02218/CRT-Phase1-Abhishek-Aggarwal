//Problem 3 -- Call by value(photocopy)//call by reference(original copy (address))

#include <iostream>
using namespace std;

void updatebyValue(int a){
    a = 500;
}

void updatebyReference(int &a){
    a = 500;
}

int main() {
    int original = 100;
    cout << original << endl;
  
    updatebyValue(original);
    cout << original << endl;
    updatebyReference(original);
    cout << original;
}


